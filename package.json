{
  "name": "zod-http-client",
  "version": "1.0.0",
  "description": "A tiny, typed HTTP client using Zod for response validation.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "npm run lint-code",
    "lint:fix": "npm run lint-code -- --fix",
    "lint-code": "eslint .",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/eslint__js": "9.14.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.3.0",
    "eslint": "9.34.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-prettier": "5.5.4",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "lint-staged": "^16.1.5",
    "prettier": "3.6.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "zod": "^4.1.5"
  },
  "dependencies": {},
  "peerDependencies": {
    "zod": ">=4 <5"
  }
}
